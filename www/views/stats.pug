extends layout

block content
    - const fmt = (value, digits = 0) => Number(value || 0).toLocaleString(undefined, { minimumFractionDigits: digits, maximumFractionDigits: digits })
    div.row.justify-content-center
        div.col-12
            div.d-flex.justify-content-between.align-items-start.flex-wrap.mb-3
                div
                    h1.h3.mb-1 Site Stats
                    if generated_at
                        p.text-muted.mb-0 Cached #{new Date(generated_at).toUTCString()} and refreshed every #{refresh_interval_hours} hours.
                    else
                        p.text-muted.mb-0 Cache not populated yet. This page will fill in after the stats cron runs.                    
            div.row
                div.col-md-4.mb-3
                    div.card.h-100
                        div.card-body
                            h2.h5 Totals
                            table.table.table-sm.mb-0.stats-table.stats-table-numeric
                                tbody
                                    tr
                                        td Alliances
                                        td.text-right= fmt(alliance_count)
                                    tr
                                        td Corporations
                                        td.text-right= fmt(corporation_count)
                                    tr
                                        td Characters
                                        td.text-right= fmt(character_count)
                div.col-md-4.mb-3
                    div.card.h-100
                        div.card-body
                            h2.h5 Largest Groups
                            table.table.table-sm.mb-0.stats-table
                                tbody
                                    tr
                                        td Corporation
                                        td.text-right
                                            div
                                                a(href=(largest_corporation_id ? '/corporation/' + largest_corporation_id : '/corp/'))= largest_corporation_name
                                            small.text-muted= fmt(largest_corporation_members) + ' members'
                                    tr
                                        td Alliance
                                        td.text-right
                                            div
                                                a(href=(largest_alliance_id ? '/alliance/' + largest_alliance_id : '/alli/'))= largest_alliance_name
                                            small.text-muted= fmt(largest_alliance_members) + ' members'
                div.col-md-4.mb-3
                    div.card.h-100
                        div.card-body
                            h2.h5 Averages
                            table.table.table-sm.mb-0.stats-table.stats-table-numeric
                                tbody
                                    tr
                                        td Avg corp size
                                        td.text-right= fmt(avg_player_corporation_members, 1)
                                    tr
                                        td Avg alliance size
                                        td.text-right= fmt(avg_alliance_members, 1)
            div.row
                div.col-md-4.mb-3
                    div.card.h-100
                        div.card-body
                            h2.h5 Characters
                            table.table.table-striped.table-sm.mb-0.stats-table.stats-table-numeric
                                tbody
                                    tr
                                        td w/ Alliance
                                        td.text-right= fmt(characters_in_alliances_count)
                                    tr
                                        td In NPC corps
                                        td.text-right= fmt(characters_in_npc_corporations_count)
                                    tr
                                        td In non-NPC corps
                                        td.text-right= fmt(characters_in_non_npc_corporations_count)
                                    tr
                                        td w/ Faction
                                        td.text-right= fmt(faction_character_count)
                                    tr
                                        td Unaffiliated
                                        td.text-right= fmt(unaffiliated_character_count)
                                    tr
                                        td History imported
                                        td.text-right= fmt(history_complete_count)
                                    tr
                                        td Pending history import
                                        td.text-right= fmt(history_pending_count)
                                    tr
                                        td Recent change flag
                                        td.text-right= fmt(recent_change_count)
                div.col-md-4.mb-3
                    div.card.h-100
                        div.card-body
                            h2.h5 Corporations
                            table.table.table-striped.table-sm.mb-0.stats-table.stats-table-numeric
                                tbody
                                    tr
                                        td Non-NPC
                                        td.text-right= fmt(player_corporation_count)
                                    tr
                                        td NPC
                                        td.text-right= fmt(npc_corporation_count)
                                    tr
                                        td w/ Faction
                                        td.text-right= fmt(faction_corporation_count)
                                    tr
                                        td Chars in faction corps
                                        td.text-right= fmt(characters_in_faction_corporations_count)
                                    tr
                                        td w/ Alliance
                                        td.text-right= fmt(allied_corporation_count)
                                    tr
                                        td Independent
                                        td.text-right= fmt(independent_corporation_count)
                                    tr
                                        td Active
                                        td.text-right= fmt(active_corporation_count)
                                    tr
                                        td Inactive
                                        td.text-right= fmt(inactive_corporation_count)
                                    tr
                                        td Open
                                        td.text-right= fmt(non_empty_corporation_count)
                                    tr
                                        td Closed
                                        td.text-right= fmt(empty_corporation_count)
                div.col-md-4.mb-3
                    div.card.h-100
                        div.card-body
                            h2.h5 Alliances
                            table.table.table-striped.table-sm.mb-0.stats-table.stats-table-numeric
                                tbody
                                    tr
                                        td Open
                                        td.text-right= fmt(populated_alliance_count)
                                    tr
                                        td Characters total
                                        td.text-right= fmt(characters_in_alliances_count)
                                    tr
                                        td Chars in faction alliances
                                        td.text-right= fmt(characters_in_faction_alliances_count)
                                    tr
                                        td w/ Faction
                                        td.text-right= fmt(faction_alliance_count)
                                    tr
                                        td Activity
                                        td.text-right= fmt(alliance_activity_score, 2)
                                    tr
                                        td Closed
                                        td.text-right= fmt(empty_alliance_count)
    p.text-muted.small.mb-0 Activity metrics are based on recruitment in the last 90 days.